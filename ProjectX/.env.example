# Environment Variables for Athena SQL Data Analyst

# Database Connection
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/analytics_demo

# Anthropic API Key (for Claude LLM)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Optional: Frontend Configuration (for proxy in development)
# In package.json, you can set "proxy": "http://localhost:8000"